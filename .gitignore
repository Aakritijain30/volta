# ============================================================
# .gitignore — Project 1: Static Webpage
# ============================================================

# ----------------------
# OS generated files
# ----------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----------------------
# Editor & IDE
# ----------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ----------------------
# Logs
# ----------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----------------------
# Local environment
# ----------------------
.env
.env.local
.env.development
.env.production

# ----------------------
# Node (if serve or any
# local tooling is used)
# ----------------------
node_modules/
package-lock.json
yarn.lock

# ----------------------
# Build / dist output
# ----------------------
dist/
build/
out/

# ----------------------
# Cache
# ----------------------
.cache/
.parcel-cache/
.sass-cache/

# ----------------------
# Temp files
# ----------------------
*.tmp
*.temp
*.bak
